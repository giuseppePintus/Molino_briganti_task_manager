<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <LinearLayout
        android:id="@+id/loginSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="MOLINO BRIGANTI"
                android:textColor="#ffffff"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Operatore Lite"
                android:textColor="#ea580c"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOperatorPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Seleziona il tuo nome:"
                android:textColor="#d1d5db"
                android:textSize="22sp" />

            <GridLayout
                android:id="@+id/operatorGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:useDefaultMargins="false" />

            <LinearLayout
                android:id="@+id/adminLoginPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:background="#243041"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accesso Admin"
                    android:textColor="#f59e0b"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <Spinner
                    android:id="@+id/adminUserSelect"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="#ffffff" />

                <EditText
                    android:id="@+id/adminPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="#ffffff"
                    android:inputType="textPassword"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:textColor="#111827"
                    android:textColorHint="#6b7280"
                    android:hint="Password admin" />

                <Button
                    android:id="@+id/adminLoginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_toolbar_button_orange"
                    android:text="Accedi come Admin"
                    android:textAllCaps="false"
                    android:textColor="#ffffff"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtLoginStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Caricamento operatori..."
                android:textColor="#9ca3af"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnApiTargetToggle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_toolbar_button_dark"
                android:text="Endpoint: SHADOW (:5001)"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnLoginRefresh"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_toolbar_button_dark"
                android:text="Aggiorna"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dashboardSection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#1a1a1a">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2d2d2d"
            android:paddingLeft="8dp"
            android:paddingTop="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/txtCurrentOperator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Operatore"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnTasks"
                android:layout_width="174dp"
                android:layout_height="62dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_toolbar_button_green"
                android:drawableLeft="@android:drawable/ic_menu_agenda"
                android:drawablePadding="6dp"
                android:text="Task"
                android:textAllCaps="true"
                android:textColor="#ffffff"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnInstant"
                android:layout_width="174dp"
                android:layout_height="62dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_toolbar_button_orange"
                android:drawableLeft="@android:drawable/ic_input_add"
                android:drawablePadding="6dp"
                android:text="Ordine Rapido"
                android:textAllCaps="true"
                android:textColor="#ffffff"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnWarehouse"
                android:layout_width="174dp"
                android:layout_height="62dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/bg_toolbar_button_red"
                android:drawableLeft="@android:drawable/ic_menu_sort_by_size"
                android:drawablePadding="6dp"
                android:text="Magazzino"
                android:textAllCaps="true"
                android:textColor="#ffffff"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="146dp"
                android:layout_height="62dp"
                android:layout_marginLeft="102dp"
                android:background="@drawable/bg_button_danger"
                android:drawableLeft="@android:drawable/ic_lock_power_off"
                android:drawablePadding="6dp"
                android:text="Esci"
                android:textAllCaps="true"
                android:textColor="#ffffff"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#ea580c" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/leftMainPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.9"
                android:orientation="vertical"
                android:layout_marginRight="6dp"
                android:background="@drawable/bg_panel"
                android:padding="6dp">

                <TextView
                    android:id="@+id/txtProductsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seleziona una categoria"
                    android:textColor="#F59E0B"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/txtInstantStepHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1/3 - Seleziona categoria"
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"
                    android:paddingLeft="4dp"
                    android:paddingTop="2dp"
                    android:paddingRight="4dp"
                    android:paddingBottom="2dp" />

                <LinearLayout
                    android:id="@+id/instantCategoryGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/instantSubcategoryGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <ScrollView
                    android:id="@+id/instantProductsScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="6dp"
                    android:background="#2d2d2d"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/instantProductsButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="4dp" />
                </ScrollView>

                <LinearLayout
                    android:id="@+id/warehouseSection"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <Button
                            android:id="@+id/btnWarehouseProductsView"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="📋 Prodotti"
                            android:textAllCaps="false"
                            android:textColor="#ffffff"
                            android:background="@drawable/bg_toolbar_button_dark" />

                        <Button
                            android:id="@+id/btnWarehouseShelvesView"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginLeft="8dp"
                            android:text="🏗 Scaffali"
                            android:textAllCaps="false"
                            android:textColor="#ffffff"
                            android:background="@drawable/bg_toolbar_button_orange" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/warehouseSectorRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSectorA"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:text="Settore A"
                            android:textAllCaps="false"
                            android:textColor="#ffffff"
                            android:background="@drawable/bg_toolbar_button_dark" />

                        <Button
                            android:id="@+id/btnSectorB"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_marginLeft="8dp"
                            android:text="Settore B"
                            android:textAllCaps="false"
                            android:textColor="#ffffff"
                            android:background="@drawable/bg_toolbar_button_dark" />

                        <Button
                            android:id="@+id/btnSectorC"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_marginLeft="8dp"
                            android:text="Settore C"
                            android:textAllCaps="false"
                            android:textColor="#ffffff"
                            android:background="@drawable/bg_toolbar_button_dark" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/warehouseProductsPanel"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:background="#111827"
                        android:padding="6dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/warehouseCategoryRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <LinearLayout
                            android:id="@+id/warehouseSubcategoryRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="vertical" />

                        <ListView
                            android:id="@+id/warehouseProductsList"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginTop="6dp"
                            android:cacheColorHint="#00000000"
                            android:divider="#334155"
                            android:dividerHeight="1dp"
                            android:listSelector="#1d4ed8"
                            android:background="#0f172a" />
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/warehouseShelvesPanel"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="8dp"
                        android:background="#111827">

                        <LinearLayout
                            android:id="@+id/warehousePositionsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="6dp" />
                    </ScrollView>
                </LinearLayout>

                <ListView
                    android:id="@+id/listProducts"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rightOrderPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_panel"
                android:padding="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prodotti ordine"
                    android:textColor="#F59E0B"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="4dp" />

                <ListView
                    android:id="@+id/listLines"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:cacheColorHint="#00000000"
                    android:divider="#3d3d3d"
                    android:dividerHeight="1dp"
                    android:listSelector="#334155"
                    android:background="#2d2d2d" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <Button
                        android:id="@+id/btnConfirmOrder"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_confirm"
                        android:drawableLeft="@android:drawable/ic_menu_send"
                        android:drawablePadding="8dp"
                        android:text="Conferma"
                        android:textAllCaps="true"
                        android:textColor="#ffffff"
                        android:textSize="17sp" />

                    <Button
                        android:id="@+id/btnClearLines"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="8dp"
                        android:background="@drawable/bg_button_danger"
                        android:drawableLeft="@android:drawable/ic_menu_delete"
                        android:drawablePadding="8dp"
                        android:text="Svuota"
                        android:textAllCaps="true"
                        android:textColor="#ffffff"
                        android:textSize="17sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
