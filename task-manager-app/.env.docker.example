# Environment variables for Docker deployment (template)
# Copy to .env.docker and customize values for your environment.

# Server
PORT=5000
NODE_ENV=production

# Database
DATABASE_URL=file:/data/molino/tasks.db

# Auth
JWT_SECRET=change-me-with-a-strong-random-secret

# Default admin (change before production use)
DEFAULT_MASTER_USER=master
DEFAULT_MASTER_PASS=change-me

# Backup paths
BACKUP_DIR=/data/molino/backups/database
BACKUP_DIR_LOCAL=/data/molino/backups/database
BACKUP_DIR_NAS=/data/molino/backups

# NAS backup service
NAS_URL=nas-backup-server
NAS_PORT=5000
NAS_PATH=/data/molino/backups

# Auto backup schedule (minutes)
BACKUP_INTERVAL_MINUTES=60

# App settings
LOG_LEVEL=info
CORS_ORIGIN=*
