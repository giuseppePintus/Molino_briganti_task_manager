// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  passwordHash String
  role      String    // 'master' or 'slave'
  name      String?   // Nome visualizzato per l'operatore
  image     String?   // URL or base64 encoded image for operators carousel
  createdAt DateTime  @default(now())
  
  createdTasks Task[] @relation("CreatedBy")
  assignedTasks Task[] @relation("AssignedTo")
  acceptedTasks Task[] @relation("AcceptedTasks")
  completedTasks Task[] @relation("CompletedBy")
  notes TaskNote[]
  
  // Relazioni ordini e viaggi
  assignedOrders Order[]
  assignedTrips  Trip[]
}

model Task {
  id                Int     @id @default(autoincrement())
  title             String
  description       String?  @db.Text
  scheduledAt       DateTime?
  assignedOperator  User?   @relation("AssignedTo", fields: [assignedOperatorId], references: [id])
  assignedOperatorId Int?
  assignedAt        DateTime?  // Quando il task viene assegnato
  estimatedMinutes  Int?
  priority          String  @default("MEDIUM")  // LOW, MEDIUM, HIGH, URGENT
  color             String  @default("#FCD34D") // hex color
  
  // Ricorrenza
  recurring         Boolean @default(false)
  recurrenceType    String? // DAILY, WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, YEARLY, CUSTOM
  recurrenceEnd     DateTime?  // Data di fine ricorrenza
  parentTaskId      Int?  // ID del task ricorrente parent
  
  createdBy         User    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById       Int
  createdAt         DateTime @default(now())
  
  acceptedAt        DateTime?  // Quando l'operatore accetta il task
  acceptedBy        User?   @relation("AcceptedTasks", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedById      Int?
  
  paused            Boolean @default(false)
  pausedAt          DateTime?
  
  completed         Boolean @default(false)
  completedBy       User?   @relation("CompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completedById     Int?
  completedAt       DateTime?  // Ora di chiusura automatica
  actualMinutes     Int?

  // Stampa scontrino "ordine interno" (operatori possono stamparlo una sola volta su termica)
  internalOrderPrintedAt DateTime?
  internalOrderPrintedById Int?
  
  notes             TaskNote[]
}

model TaskNote {
  id        Int     @id @default(autoincrement())
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    Int
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
  note      String
  createdAt DateTime @default(now())
}

// Modelli per gestione magazzino
model Article {
  id                Int       @id @default(autoincrement())
  code              String    // es. F-0-SP35-5 (NON univoco: stesso articolo può essere in più posizioni)
  name              String    // es. FARINA 0 SP35 da 5 kg
  description       String?
  category          String?   // Categoria (es. FARINE, SEMOLE, MANGIMI, ecc.)
  unit              String    @default("kg")  // Unità di misura
  weightPerUnit     Float     @default(1)     // Peso singolo collo in kg (es. 10 per sacco da 10kg)
  barcode           String?   // Codice a barre EAN/QR
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  inventory         Inventory?
  shelfEntries      ShelfEntry[]
  stockAlerts       StockAlert[]
  orderItems        OrderItem[]
}

model Inventory {
  id                Int       @id @default(autoincrement())
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId         Int       @unique
  currentStock      Int       @default(0)  // Quantità attuale in magazzino
  minimumStock      Int       @default(0)  // Soglia di avviso (LOW_STOCK)
  criticalStock     Int       @default(0)  // Soglia critica (CRITICAL) - più bassa di minimumStock
  reserved          Int       @default(0)  // Quantità prenotata (assegnata a ordini non completati)
  // position          String?   // Posizione fisica (es. A1.1) - USATO COME CHIAVE DI MATCHING - TEMPORANEAMENTE DISABILITATO
  shelfPosition     String?   // Posizione scaffale unica combinata con codice (es. A1.1-F-0-5) - MANTENUTO PER COMPATIBILITÀ
  batch             String?   // Lotto/Batch
  expiry            String?   // Scadenza
  lastUpdated       DateTime  @updatedAt
  notes             String?
  // Snooze avvisi: settato quando viene creato un ordine interno dalla pagina Avvisi.
  // L'avviso resta visibile ma non incide sul contatore finché il magazzino
  // non viene ricaricato (shelfTotal > snoozedAtStock).
  snoozedAt         DateTime?
  snoozedAtStock    Int?
  
  movements         StockMovement[]
  alerts            StockAlert[]
}

model StockMovement {
  id                Int       @id @default(autoincrement())
  inventory         Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryId       Int
  type              String    // IN, OUT, ADJUSTMENT
  quantity          Int
  reason            String?   // Motivo del movimento (es. ordine, reso, inventario)
  orderId           Int?      // Collegamento a ordine se applicabile
  notes             String?
  createdAt         DateTime  @default(now())
  createdBy         Int       // ID utente che ha fatto il movimento
}

model StockAlert {
  id                Int       @id @default(autoincrement())
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId         Int
  inventory         Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryId       Int
  alertType         String    // LOW_STOCK, CRITICAL
  currentStock      Int       // Quantità al momento dell'avviso
  minimumStock      Int       // Soglia impostata
  isResolved        Boolean   @default(false)
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  
  @@index([isResolved])
  @@index([createdAt])
}

// Posizioni scaffale del magazzino
model ShelfPosition {
  id                Int       @id @default(autoincrement())
  code              String    @unique  // es. A1.1, B2.3, "Merce a terra"
  description       String?   // Descrizione opzionale
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
}

// Entrate scaffale: articolo × posizione × lotto (possono esserci più lotti dello stesso articolo)
model ShelfEntry {
  id            Int      @id @default(autoincrement())
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId     Int
  positionCode  String   // riferimento a ShelfPosition.code
  quantity      Int      @default(0)
  batch         String?  // Lotto
  expiry        String?  // Scadenza
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([articleId, positionCode])
  @@index([positionCode])
}

model OrderItem {
  id                Int       @id @default(autoincrement())
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId           Int
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Restrict)
  articleId         Int
  quantityOrdered   Int
  quantityDelivered Int       @default(0)
  unitPrice         Float?
  createdAt         DateTime  @default(now())
}

// ============================================
// NUOVE TABELLE PER ORDINI, VIAGGI, CLIENTI
// ============================================

model Customer {
  id                Int       @id @default(autoincrement())
  code              String?   @unique  // Codice cliente (es. CLI001)
  name              String    // Nome/Ragione sociale
  address           String?
  city              String?
  province          String?
  cap               String?
  phone             String?
  email             String?
  piva              String?   // Partita IVA
  cf                String?   // Codice Fiscale
  notes             String?
  openingTime       String?   // Orario apertura (es. "08:00")
  closingTime       String?   // Orario chiusura (es. "18:00")
  deliveryStartTime String?   // Orario inizio consegne
  deliveryEndTime   String?   // Orario fine consegne
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  orders            Order[]
}

model Order {
  id                Int       @id @default(autoincrement())
  type              String    // 'consegnato' (delivery) o 'ritira' (pickup)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId        Int?
  clientName        String?   // Nome cliente (per compatibilità se non in DB)
  
  // Prodotti (JSON string per flessibilità)
  products          String?   @db.Text // JSON array: [{product, quantity, unit}]
  
  // Collegamento viaggio (solo per consegne)
  trip              Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
  tripId            Int?
  
  // Operatore assegnato (per ritiri)
  assignedOperator  User?     @relation(fields: [assignedOperatorId], references: [id], onDelete: SetNull)
  assignedOperatorId Int?
  
  // Data e ora programmata
  dateTime          DateTime?
  
  // Stato e Timeline
  status            String    @default("pending")  // pending, in_progress, completed, cancelled
  assignedAt        DateTime? // Quando è stato assegnato all'operatore
  acceptedAt        DateTime? // Quando l'operatore ha accettato
  completedAt       DateTime?
  
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  items             OrderItem[]
}

model Trip {
  id                Int       @id @default(autoincrement())
  name              String    // Nome viaggio (es. "Viaggio Milano Nord")
  date              DateTime  // Data del viaggio
  
  // Operatore assegnato
  assignedOperator  User?     @relation(fields: [assignedOperatorId], references: [id], onDelete: SetNull)
  assignedOperatorId Int?
  
  // Veicolo
  vehicleId         Int?
  vehicleName       String?
  
  // Sequenza ordini nel viaggio (array JSON)
  sequence          String?   @db.Text // JSON array: [ordine_id1, ordine_id2, ...]
  
  // Stato
  status            String    @default("planned")  // planned, in_progress, completed, cancelled
  startedAt         DateTime?
  completedAt       DateTime?
  
  // Accettazione e stampa
  accepted          Boolean   @default(false)
  acceptedAt        DateTime?
  printed           Boolean   @default(false)
  printedAt         DateTime?
  
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  orders            Order[]
}

model CompanySettings {
  id                Int       @id @default(autoincrement())
  key               String    @unique  // Chiave impostazione
  value             String    @db.Text // Valore (JSON string per oggetti complessi)
  updatedAt         DateTime  @updatedAt
}

model Vehicle {
  id                Int       @id @default(autoincrement())
  name              String    // Nome veicolo (es. "Furgone 1")
  plate             String?   // Targa
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
}

model Holiday {
  id                Int       @id @default(autoincrement())
  date              DateTime  @unique  // Data festivo
  description       String?   // Descrizione opzionale
  createdAt         DateTime  @default(now())
}

model Warehouse {
  id                Int       @id @default(autoincrement())
  posizione         String    @unique  // Posizione scaffale (es. A1.1)
  nome              String    // Nome articolo
  codice            String?   // Codice articolo
  lotto             String?   // Lotto/Batch
  scadenza          DateTime? // Data scadenza
  quantita          Int       @default(0)  // Quantità in magazzino
  annotazioni       String?   // Note
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}